{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "tsc -p tsconfig.test.json && node tests/run-tests.cjs",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm test && npm run test:unit"
  },
  "dependencies": {
    "vue": "^3.3.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "4.2.3",
    "@vue/test-utils": "^2.4.10",
    "@vitest/coverage-v8": "^0.34.6",
    "jsdom": "^22.1.0",
    "typescript": "5.0.4",
    "vite": "4.4.5",
    "vitest": "^0.34.6",
    "vue-tsc": "1.8.5"
  }
}
